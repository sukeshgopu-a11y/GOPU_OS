{
  "name": "social-media-content-automation-saas",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev:api": "tsx watch apps/api/src/main.ts",
    "dev:worker": "tsx watch apps/api/src/worker/main.ts",
    "dev:web": "next dev apps/web -p 3000",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "lint": "tsc -p apps/api/tsconfig.build.json --noEmit && tsc -p apps/web/tsconfig.json --noEmit",
    "build": "npm run db:generate && tsc -p apps/api/tsconfig.build.json && next build apps/web",
    "start:api": "node dist/api/main.js",
    "start:worker": "node dist/api/worker/main.js",
    "start:web": "next start apps/web -p 3000"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.637.0",
    "@nestjs/common": "^10.4.4",
    "@nestjs/core": "^10.4.4",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/platform-express": "^10.4.4",
    "@prisma/client": "^5.19.1",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.12.12",
    "express": "^4.19.2",
    "ioredis": "^5.4.1",
    "next": "^14.2.8",
    "openai": "^4.56.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/node": "^22.5.4",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "prisma": "^5.19.1",
    "tailwindcss": "^3.4.10",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
