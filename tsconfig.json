{
  "compilerOptions": {
    "target": "ES2020", "module": "ES2020", "lib": ["ES2020"],
    "strict": false, "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "moduleResolution": "node10", "ignoreDeprecations": "6.0",
    "resolveJsonModule": true, "skipLibCheck": true,
    "outDir": "dist", "types": ["node"]
  },
  "include": ["api/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
