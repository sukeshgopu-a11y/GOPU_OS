{
  "crons": [{ "path": "/api/cron/daily-social-trigger", "schedule": "0 3 * * *" }],
  "functions": {
    "api/**/*.ts": { "includeFiles": "lib/**" },
    "api/**/*.js": { "includeFiles": "lib/**" }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
